---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Personal site of Eden Jaeger.',
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Eden Jaeger"
      href="/rss.xml"
    />
  </head>
  <body>
    <header class="site">
      <a class="name" href="/">Eden Jaeger</a>
      <nav>
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      <hr />
      © {new Date().getFullYear()} Eden Jaeger · <a href="/rss.xml">RSS</a>
    </footer>
  </body>
</html>
